generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── League & Fixtures ────────────────────────────────────────────────────────

model League {
  id          String       @id @default(cuid())
  name        String
  trophyName  String       @default("Championship Trophy")
  season      Int          @default(1)
  tier        Int          @default(1)
  status      LeagueStatus @default(ACTIVE)
  startedAt   DateTime     @default(now())
  endsAt      DateTime?
  teams       Team[]
  fixtures    Fixture[]
  createdAt   DateTime     @default(now())
}

enum LeagueStatus {
  ACTIVE
  COMPLETED
}

model Team {
  id               String   @id @default(cuid())
  name             String
  leagueId         String
  league           League   @relation(fields: [leagueId], references: [id])
  players          Player[]
  formation        String   @default("4-4-2")
  overallAtk       Int      @default(50)
  overallMid       Int      @default(50)
  overallDef       Int      @default(50)
  baseTactics      Json?
  isUserControlled Boolean  @default(false)
  logoSvg          String?
  jerseyColor      String   @default("#ff5252")
  budget           Int      @default(5000000)

  homeFixtures  Fixture[]         @relation("HomeTeam")
  awayFixtures  Fixture[]         @relation("AwayTeam")
  transfersOut  TransferListing[] @relation("SellingTeam")
  transfersIn   TransferLog[]     @relation("BuyingTeam")
  transfersFrom TransferLog[]     @relation("SellingTeamLog")
  userSession   UserSession?
  friendlyHome  FriendlyMatch[]   @relation("FriendlyHome")
  friendlyAway  FriendlyMatch[]   @relation("FriendlyAway")

  @@index([leagueId])
}

model Player {
  id            String   @id @default(cuid())
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id])
  name          String
  position      Position
  pace          Int
  shooting      Int
  passing       Int
  defending     Int
  stamina       Int
  fitness       Int      @default(100)
  morale        Int      @default(70)
  starRating    Int      @default(1)
  marketValue   Int      @default(100000)
  avatarSvg     String?
  nationality   String   @default("International")
  age           Int      @default(24)
  isInUserSquad Boolean  @default(false)
  // EXP system
  playerExp     Int      @default(0)
  playerLevel   Int      @default(1)

  transferListing TransferListing?
  transferLogs    TransferLog[]
  trainingLogs    TrainingLog[]
  mvpMatches      MatchResult[]    @relation("MVP")

  @@index([teamId])
}

enum Position {
  GK
  DF
  MF
  FW
}

model Fixture {
  id          String        @id @default(cuid())
  leagueId    String
  league      League        @relation(fields: [leagueId], references: [id])
  round       Int
  homeTeamId  String
  homeTeam    Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String
  awayTeam    Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  status      FixtureStatus @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  matchResult MatchResult?
  userTactics UserTactics?

  @@index([leagueId, round])
}

enum FixtureStatus {
  SCHEDULED
  SIMULATED
}

model MatchResult {
  id          String   @id @default(cuid())
  fixtureId   String?  @unique
  fixture     Fixture? @relation(fields: [fixtureId], references: [id])
  // For friendly matches
  friendlyId  String?  @unique
  friendly    FriendlyMatch? @relation(fields: [friendlyId], references: [id])
  homeTactics Json
  awayTactics Json
  events      Json
  narrative   String?
  // EXP + MVP
  mvpPlayerId    String?
  mvpPlayer      Player?  @relation("MVP", fields: [mvpPlayerId], references: [id])
  homeExpGained  Int      @default(0)
  awayExpGained  Int      @default(0)
  createdAt   DateTime @default(now())
}

model UserTactics {
  id          String   @id @default(cuid())
  fixtureId   String   @unique
  fixture     Fixture  @relation(fields: [fixtureId], references: [id])
  teamId      String
  tactics     Json
  submittedAt DateTime @default(now())
}

// ─── Training ─────────────────────────────────────────────────────────────────

model TrainingLog {
  id         String   @id @default(cuid())
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id])
  date       String   // YYYY-MM-DD (UTC) — one record per player per day
  statGained String   // "pace" | "shooting" | "passing" | "defending" | "stamina"
  amount     Int
  trainedAt  DateTime @default(now())

  @@unique([playerId, date])
  @@index([playerId])
}

// ─── Transfer Market ──────────────────────────────────────────────────────────

model TransferListing {
  id           String        @id @default(cuid())
  playerId     String        @unique
  player       Player        @relation(fields: [playerId], references: [id])
  fromTeamId   String
  fromTeam     Team          @relation("SellingTeam", fields: [fromTeamId], references: [id])
  sellerWallet String
  price        Int           // in-game currency cents (for AI market compat)
  priceSOL     Float         @default(0)
  priceUSD     Int           @default(0)   // USD cents: $5000 = 500000
  isSOLListing Boolean       @default(false)
  isUSDListing Boolean       @default(false) // true = USD in-game currency
  escrowTxHash String?
  status       ListingStatus @default(LISTED)
  listedAt     DateTime      @default(now())
  soldAt       DateTime?
}

enum ListingStatus {
  LISTED
  SOLD
  CANCELLED
}

model TransferLog {
  id          String         @id @default(cuid())
  playerId    String
  player      Player         @relation(fields: [playerId], references: [id])
  fromTeamId  String?
  fromTeam    Team?          @relation("SellingTeamLog", fields: [fromTeamId], references: [id])
  toTeamId    String
  toTeam      Team           @relation("BuyingTeam", fields: [toTeamId], references: [id])
  price       Int
  priceSOL    Float          @default(0)
  source      TransferSource @default(MARKET)
  createdAt   DateTime       @default(now())
}

enum TransferSource {
  MARKET
  GACHA
  FRIENDLY
}

// ─── Gacha / Spin ─────────────────────────────────────────────────────────────

model GachaSpin {
  id         String     @id @default(cuid())
  walletAddr String
  tier       GachaTier
  txHash     String     @unique
  playerId   String?
  status     SpinStatus @default(PENDING)
  createdAt  DateTime   @default(now())
}

enum GachaTier {
  STANDARD
  PREMIUM
}

enum SpinStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── Friendly Match ───────────────────────────────────────────────────────────

model FriendlyMatch {
  id            String        @id @default(cuid())
  code          String        @unique // 6-char uppercase code
  hostTeamId    String
  hostTeam      Team          @relation("FriendlyHome", fields: [hostTeamId], references: [id])
  guestTeamId   String?
  guestTeam     Team?         @relation("FriendlyAway", fields: [guestTeamId], references: [id])
  status        FriendlyStatus @default(WAITING)
  pusherChannel String        // "friendly-{code}"
  expiresAt     DateTime      // now + 30 min if no guest joins
  hostReady     Boolean       @default(false)
  guestReady    Boolean       @default(false)
  matchResult   MatchResult?
  createdAt     DateTime      @default(now())

  @@index([code])
  @@index([status])
}

enum FriendlyStatus {
  WAITING    // waiting for guest
  READY      // both joined, setting tactics
  PLAYING    // match in progress
  COMPLETED  // match done
  EXPIRED    // nobody joined in time
  CANCELLED  // host cancelled
}

// ─── Portal / Inbox ───────────────────────────────────────────────────────────

model PortalMessage {
  id        String      @id @default(cuid())
  type      MessageType
  title     String
  content   String
  metadata  Json?
  isRead    Boolean     @default(false)
  // Per-user messages (null = global/all users)
  walletAddress String?
  createdAt DateTime    @default(now())

  @@index([walletAddress])
}

enum MessageType {
  NEWS
  TRANSFER
  LEAGUE
  GACHA
  SYSTEM
  TRAINING
  FRIENDLY
  EXP
}

// ─── User Squad ───────────────────────────────────────────────────────────────

model UserSquad {
  id         String   @id @default(cuid())
  playerId   String   @unique
  slotIndex  Int?
  acquiredAt DateTime @default(now())
}

// ─── User Session ─────────────────────────────────────────────────────────────

model UserSession {
  id            String   @id @default(cuid())
  solanaWallet  String   @unique
  privyUserId   String?  @unique
  teamId        String   @unique
  team          Team     @relation(fields: [teamId], references: [id])
  displayName   String?
  avatarBase64  String?
  // Manager RPG
  managerLevel  Int      @default(1)
  managerExp    Int      @default(0)
  totalWins     Int      @default(0)
  totalMatches  Int      @default(0)
  // In-game USD currency (stored as cents: $500.00 = 50000)
  usdBalance    Int      @default(0)
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())
}

model BoostLog {
  id          String   @id @default(cuid())
  playerId    String
  wallet      String
  stat        String
  gain        Int
  txHash      String
  solPaid     Float
  createdAt   DateTime @default(now())

  @@index([playerId])
  @@index([wallet])
}
