# ─── Database ─────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_manager_fm"
# Production (Aiven — see aiven_step.txt):
# DATABASE_URL="postgresql://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?sslmode=require"

# ─── AI ───────────────────────────────────────────────────────────────────────
# Gemini free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# ─── Solana ───────────────────────────────────────────────────────────────────
# Your Solana wallet address (base58) that receives gacha spin SOL payments.
# Get from Phantom: open wallet → click address to copy.
NEXT_PUBLIC_SOLANA_TREASURY="your-phantom-wallet-address-here"

# Solana RPC endpoint. For devnet testing, use the public endpoint below (no signup needed).
# For production mainnet, use Helius free tier: https://helius.dev
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# Random secret to protect the cron endpoint from unauthorized calls.
# Generate: openssl rand -hex 32
CRON_SECRET="generate-a-random-secret-here"
